# ===========================================
# Configuration API Inovex - NestJS
# ===========================================
# Copiez ce fichier en .env et remplissez les valeurs

# ----- Environment -----
NODE_ENV=development
# Options: development, preprod, production

# ----- Server -----
PORT=3010

# ----- Database SQL Server -----
DB_HOST=localhost
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ----- JWT Authentication -----
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRATION=86400
# JWT_EXPIRATION en secondes (86400 = 24h)

# ----- Rate Limiting -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
# TTL en millisecondes, LIMIT = nombre de requêtes max par TTL

# ----- Logging -----
LOG_LEVEL=debug
# Options: error, warn, info, debug

# ----- CORS -----
CORS_ORIGIN=http://localhost:4200