# ===========================================
# Configuration PRODUCTION - API Cahier de Soins
# ===========================================
# IMPORTANT: Copiez ce fichier en .env.prod et remplissez les vraies valeurs
# NE JAMAIS commiter le fichier .env.prod avec les vraies valeurs !

# ----- Environment -----
NODE_ENV=prod

# ----- Server -----
PORT=3100

# ----- Database SQL Server (Production) -----
# Utilisez un utilisateur SQL Server dédié avec permissions minimales
DB_HOST_PROD=your-production-db-host
DB_PORT_PROD=1433
DB_USER_PROD=cahier_soins_app
DB_PASSWORD_PROD=CHANGE_ME_STRONG_PASSWORD_64_CHARS_MIN
DB_NAME_PROD=cahier_soins

# ----- JWT Authentication -----
# Générez avec: openssl rand -base64 64
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# Durée de validité du token en secondes (86400 = 24h)
JWT_EXPIRATION=86400

# ----- Rate Limiting -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- Logging -----
LOG_LEVEL=warn

# ----- CORS -----
# Liste des origines autorisées séparées par des virgules
ALLOWED_ORIGINS=https://fr-couvinove301.prod.paprec.fr

# ----- HTTPS (optionnel si derrière reverse proxy) -----
# TRUST_PROXY=true

# ----- SSL Certificates -----
# Chemin des certificats SSL dans le conteneur (montés via docker-compose)
SSL_CERT_PATH=/app/certs/cert.cer
SSL_KEY_PATH=/app/certs/cert.key
