# ===========================================
# Configuration PREPROD - API Inovex
# ===========================================
# Copiez ce fichier en .env.preprod et remplissez les vraies valeurs
# NE JAMAIS commiter le fichier .env.preprod avec les vraies valeurs !

# ----- Environment -----
NODE_ENV=preprod

# ----- Server -----
PORT=3101

# ----- Database SQL Server (Préprod) -----
DB_HOST_PREPROD=your-preprod-db-host
DB_PORT_PREPROD=1433
DB_USER_PREPROD=your_preprod_user
DB_PASSWORD_PREPROD=CHANGE_ME_STRONG_PASSWORD
DB_NAME_PREPROD=your_preprod_db

# ----- JWT Authentication -----
# Générez avec: openssl rand -base64 64
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRATION=86400

# ----- Rate Limiting -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- Logging -----
LOG_LEVEL=info

# ----- CORS -----
ALLOWED_ORIGINS=https://fr-couvinove301.prepprod.paprec.fr

# ----- SSL Certificates -----
SSL_CERT_PATH=C:/certs/cert.cer
SSL_KEY_PATH=C:/certs/cert.key
